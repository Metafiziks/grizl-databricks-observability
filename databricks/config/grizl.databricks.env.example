# Copy to databricks/config/grizl.databricks.env and fill in real values.
# Do not commit real values — grizl.databricks.env is gitignored.
# Variables use `export` so they are available to all subprocesses after `source`.

# ── Databricks workspace ─────────────────────────────────────────────────────
export DATABRICKS_HOST=https://<YOUR_WORKSPACE>.cloud.databricks.com

# SQL warehouse used for provisioning SQL views and running SQL alerts.
# Find it in Databricks SQL → SQL Warehouses → <warehouse> → Connection details.
export DATABRICKS_WAREHOUSE_ID=

# Unity Catalog coordinates
export DATABRICKS_CATALOG=grizl
export DATABRICKS_SCHEMA=observability
export DATABRICKS_RAW_TABLE=raw_logs

# ── GCP / ingestion ──────────────────────────────────────────────────────────
# GCS bucket for the Pub/Sub Cloud Storage export subscription.
# The subscription exports Pub/Sub messages as newline-delimited JSON every 60s.
# Runs in parallel to the existing pull subscription (used by grizl-log-forwarder).
# No changes to grizl-log-forwarder are required.
#
# Setup (once):
#   gsutil mb -l <REGION> gs://<GRIZL_GCS_LOGS_BUCKET>
#   gcloud pubsub subscriptions create grizl-logs-gcs-export \
#     --topic=<PUBSUB_TOPIC> --project=<GCP_PROJECT_ID> \
#     --cloud-storage-bucket=<GRIZL_GCS_LOGS_BUCKET> \
#     --cloud-storage-file-prefix=logs/ --cloud-storage-file-suffix=.jsonl \
#     --cloud-storage-max-duration=60s --cloud-storage-output-format=text
#
# Or use: npm --prefix databricks run gcs-subscription <BUCKET>
export GRIZL_GCS_LOGS_BUCKET=
export GRIZL_GCS_LOGS_PATH=gs://${GRIZL_GCS_LOGS_BUCKET}/logs/
export GCP_PROJECT_ID=
export PUBSUB_TOPIC=

# ── DLT / Asset Bundle ───────────────────────────────────────────────────────
# IDs populated after 'databricks bundle deploy'
export DATABRICKS_DLT_PIPELINE_ID=
export DATABRICKS_ANOMALY_JOB_ID=

# ── Genie (AI/BI) — optional evidence agent ──────────────────────────────────
# Create the Genie space via the CLI (recommended):
#   source databricks/config/grizl.databricks.env
#   bash databricks/scripts/genie-mgmt.sh create
# Then paste the returned space_id below.
# Or create manually: AI/BI → Genie → New space → add tables from grizl.observability.*
export DATABRICKS_GENIE_SPACE_ID=

# ── Lakehouse Monitoring ─────────────────────────────────────────────────────
export DATABRICKS_MONITOR_TABLE=grizl.observability.raw_logs

# ── Service principal (OAuth M2M) ────────────────────────────────────────────
# Create in the Databricks account console → Service principals.
# Grant the SP: USE CATALOG, USE SCHEMA, SELECT on grizl.observability.*
# DATABRICKS_CLIENT_SECRET goes in GCP Secret Manager — not here.
export DATABRICKS_CLIENT_ID=

# ── GitHub issue creation and Copilot handoff ────────────────────────────────
# These variables are passed as Workflow job parameters in databricks.yml.
# They are listed here for reference; set them as Databricks Workflow parameters
# or in the bundle target overrides.

# GitHub PAT with issues:write permission.
# export DATABRICKS_GITHUB_TOKEN=

# JSON map of service name → GitHub repo (owner/repo format).
# grizl-log-forwarder maps to the backend repo because it runs there.
# export DATABRICKS_REPO_MAP_JSON={"grizl-backend":"<owner>/grizl-backend","grizl-frontend":"<owner>/grizl-frontend","grizl-log-forwarder":"<owner>/grizl-backend"}

# Fallback repo used when service is not in the map.
# export DATABRICKS_GITHUB_FALLBACK_REPO=<owner>/grizl-backend

# GitHub Copilot Coding Agent assignment.
# export DATABRICKS_COPILOT_ENABLED=true
# export DATABRICKS_COPILOT_ASSIGNEE=Copilot
